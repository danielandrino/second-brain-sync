#!/bin/bash

# Bidirectional sync between internal/ and an external folder
# Runs before every commit. Syncs all regular files (see exclusions below).
# Text files (no NUL in first 8KB): 3-way merge with git merge-file when both sides changed.
# Binary files: conflict → abort; human picks a side.

# ── Configuration ──────────────────────────────────────────────────────────────
EXTERNAL_DIR="${SECOND_BRAIN_DIR:-}"
# Keep these exclusions in sync with hooks/post-commit
# ───────────────────────────────────────────────────────────────────────────────

if [ -z "$EXTERNAL_DIR" ]; then
    echo "⚠ pre-commit: SECOND_BRAIN_DIR is not set. Skipping sync." >&2
    echo "  Set it in your shell profile or .git/hooks/pre-commit" >&2
    exit 0
fi

INTERNAL_DIR="$(git rev-parse --show-toplevel)/internal"

# Skip if either dir doesn't exist
if [ ! -d "$EXTERNAL_DIR" ] || [ ! -d "$INTERNAL_DIR" ]; then
    exit 0
fi

_ext_resolved="$(cd "$EXTERNAL_DIR" && pwd)" || exit 0
_home_resolved="$(cd "$HOME" && pwd)" || exit 0
if [[ "$_ext_resolved" == "/" ]] || [[ "$_ext_resolved" == "$_home_resolved" ]]; then
    echo "⚠ pre-commit: SECOND_BRAIN_DIR must not be / or your home directory. Skipping sync." >&2
    exit 0
fi
unset _ext_resolved _home_resolved

HAS_CONFLICTS=0
SYNCED_FILES=()
CONFLICTED_FILES=()

# Paths under dir as ./relative/path (same as find .)
collect_sync_paths() {
    local dir="$1"
    (cd "$dir" && find . -type f \
        ! -path '*/.obsidian/*' \
        ! -path '*/.trash/*' \
        ! -name '.DS_Store' \
        ! -name '*.tmp' 2>/dev/null)
}

# Binary if NUL appears in first 8000 bytes (Git-style heuristic). Exit 0 = binary.
is_probably_binary() {
    local f="$1"
    [ ! -f "$f" ] && return 0
    head -c 8000 "$f" 2>/dev/null | LC_ALL=C grep -q $'\0'
}

# Detect OS for correct md5 command
if command -v md5sum &>/dev/null; then
    md5cmd() { md5sum "$1" | cut -d' ' -f1; }
elif command -v md5 &>/dev/null; then
    md5cmd() { md5 -q "$1"; }
else
    echo "⚠ pre-commit: No md5 command found. Skipping sync." >&2
    exit 0
fi

ALL_FILES=$(collect_sync_paths "$INTERNAL_DIR"; collect_sync_paths "$EXTERNAL_DIR")
ALL_FILES=$(echo "$ALL_FILES" | sort -u)

while IFS= read -r file; do
    [ -z "$file" ] && continue

    file="${file#./}"

    project_file="$INTERNAL_DIR/$file"
    external_file="$EXTERNAL_DIR/$file"

    project_hash=""
    external_hash=""
    head_hash=""

    [ -f "$project_file" ] && project_hash=$(md5cmd "$project_file")
    [ -f "$external_file" ] && external_hash=$(md5cmd "$external_file")

    head_hash=""
    head_tmp=$(mktemp)
    if git show "HEAD:internal/$file" > "$head_tmp" 2>/dev/null; then
        head_hash=$(md5cmd "$head_tmp")
    fi
    rm -f "$head_tmp"

    [ "$project_hash" = "$external_hash" ] && continue

    if [ -z "$head_hash" ]; then
        if [ -f "$project_file" ] && [ ! -f "$external_file" ]; then
            continue
        elif [ ! -f "$project_file" ] && [ -f "$external_file" ]; then
            mkdir -p "$(dirname "$project_file")"
            cp "$external_file" "$project_file"
            git add "$project_file"
            SYNCED_FILES+=("$file (external → project, new file)")
            continue
        elif [ ! -f "$project_file" ] && [ ! -f "$external_file" ]; then
            continue
        else
            CONFLICTED_FILES+=("$file (no committed base — internal and external differ; pick one, stage, commit)")
            HAS_CONFLICTS=1
            continue
        fi
    fi

    project_changed=false
    external_changed=false

    if [ "$project_hash" != "$head_hash" ]; then
        project_changed=true
    fi
    if [ "$external_hash" != "$head_hash" ]; then
        external_changed=true
    fi

    if [ "$external_changed" = true ] && [ "$project_changed" = false ]; then
        if [ -f "$external_file" ]; then
            mkdir -p "$(dirname "$project_file")"
            cp "$external_file" "$project_file"
            git add "$project_file"
            SYNCED_FILES+=("$file (external → project)")
        else
            if [ -f "$project_file" ]; then
                rm "$project_file"
                git add "$project_file"
                SYNCED_FILES+=("$file (deleted, synced from external)")
            fi
        fi
        continue
    fi

    if [ "$project_changed" = true ] && [ "$external_changed" = false ]; then
        continue
    fi

    if [ "$project_changed" = true ] && [ "$external_changed" = true ]; then
        if [ ! -f "$project_file" ] || [ ! -f "$external_file" ]; then
            CONFLICTED_FILES+=("$file (one side deleted, other side modified)")
            HAS_CONFLICTS=1
            continue
        fi

        if is_probably_binary "$project_file" || is_probably_binary "$external_file"; then
            CONFLICTED_FILES+=("$file (binary — both sides changed; copy one version over the other, then commit)")
            HAS_CONFLICTS=1
            continue
        fi

        base_tmp=$(mktemp)
        if ! git show "HEAD:internal/$file" > "$base_tmp" 2>/dev/null; then
            rm -f "$base_tmp"
            CONFLICTED_FILES+=("$file (new on both sides)")
            HAS_CONFLICTS=1
            continue
        fi

        project_tmp=$(mktemp)
        cp "$project_file" "$project_tmp"

        git merge-file "$project_tmp" "$base_tmp" "$external_file"
        merge_result=$?

        if [ $merge_result -eq 0 ]; then
            cp "$project_tmp" "$project_file"
            git add "$project_file"
            SYNCED_FILES+=("$file (auto-merged)")
        else
            cp "$project_tmp" "$project_file"
            CONFLICTED_FILES+=("$file")
            HAS_CONFLICTS=1
        fi

        rm -f "$base_tmp" "$project_tmp"
    fi

done <<< "$ALL_FILES"

if [ ${#SYNCED_FILES[@]} -gt 0 ]; then
    echo "✔ Pre-commit sync:"
    for f in "${SYNCED_FILES[@]}"; do
        echo "  $f"
    done
fi

if [ $HAS_CONFLICTS -eq 1 ]; then
    echo "" >&2
    echo "⚠ Commit aborted — conflicts detected:" >&2
    for f in "${CONFLICTED_FILES[@]}"; do
        echo "  ✗ $f" >&2
    done
    echo "" >&2
    echo "Resolve: for text files with conflict markers, edit then commit again." >&2
    echo "For binary files or \"no base\", choose internal or external, stage, commit." >&2
    exit 1
fi

exit 0
