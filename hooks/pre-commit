#!/bin/bash

# Bidirectional sync between internal/ and an external folder
# Runs before every commit. Detects changes on both sides and:
#   - If only external changed: copies external → project (auto-sync)
#   - If only project changed: does nothing (post-commit handles project → external)
#   - If both changed: attempts 3-way merge using HEAD as base
#     - If merge succeeds: updates both sides
#     - If merge has conflicts: aborts commit, shows conflicted files

# ── Configuration ──────────────────────────────────────────────────────────────
EXTERNAL_DIR="${SECOND_BRAIN_DIR:-}"
# ───────────────────────────────────────────────────────────────────────────────

if [ -z "$EXTERNAL_DIR" ]; then
    echo "⚠ pre-commit: SECOND_BRAIN_DIR is not set. Skipping sync." >&2
    echo "  Set it in your shell profile or .git/hooks/pre-commit" >&2
    exit 0
fi

INTERNAL_DIR="$(git rev-parse --show-toplevel)/internal"

# Skip if either dir doesn't exist
if [ ! -d "$EXTERNAL_DIR" ] || [ ! -d "$INTERNAL_DIR" ]; then
    exit 0
fi

HAS_CONFLICTS=0
SYNCED_FILES=()
CONFLICTED_FILES=()

# Detect OS for correct md5 command
if command -v md5sum &>/dev/null; then
    md5cmd() { md5sum "$1" | cut -d' ' -f1; }
    md5pipe() { md5sum | cut -d' ' -f1; }
elif command -v md5 &>/dev/null; then
    md5cmd() { md5 -q "$1"; }
    md5pipe() { md5; }
else
    echo "⚠ pre-commit: No md5 command found. Skipping sync." >&2
    exit 0
fi

# Find all markdown files across both sides
ALL_FILES=$(cd "$INTERNAL_DIR" && find . -name "*.md" -type f; cd "$EXTERNAL_DIR" && find . -name "*.md" -type f)
ALL_FILES=$(echo "$ALL_FILES" | sort -u)

while IFS= read -r file; do
    [ -z "$file" ] && continue

    # Strip leading ./
    file="${file#./}"

    project_file="$INTERNAL_DIR/$file"
    external_file="$EXTERNAL_DIR/$file"

    # Get hashes (empty string if file doesn't exist)
    project_hash=""
    external_hash=""
    head_hash=""

    [ -f "$project_file" ] && project_hash=$(md5cmd "$project_file")
    [ -f "$external_file" ] && external_hash=$(md5cmd "$external_file")

    # Get HEAD version hash
    head_content=$(git show "HEAD:internal/$file" 2>/dev/null)
    if [ $? -eq 0 ]; then
        head_hash=$(echo "$head_content" | md5pipe)
    fi

    # If project and external are the same, nothing to do
    [ "$project_hash" = "$external_hash" ] && continue

    # If file doesn't exist in HEAD (never committed), we can't 3-way merge.
    if [ -z "$head_hash" ]; then
        if [ -f "$project_file" ] && [ ! -f "$external_file" ]; then
            continue
        elif [ ! -f "$project_file" ] && [ -f "$external_file" ]; then
            mkdir -p "$(dirname "$project_file")"
            cp "$external_file" "$project_file"
            git add "$project_file"
            SYNCED_FILES+=("$file (external → project, new file)")
            continue
        else
            echo "⚠ Both sides have different versions of $file (no base to merge). Keeping project version." >&2
            continue
        fi
    fi

    # Determine what changed relative to HEAD
    project_changed=false
    external_changed=false

    if [ "$project_hash" != "$head_hash" ]; then
        project_changed=true
    fi
    if [ "$external_hash" != "$head_hash" ]; then
        external_changed=true
    fi

    # Case 1: Only external changed → copy to project
    if [ "$external_changed" = true ] && [ "$project_changed" = false ]; then
        if [ -f "$external_file" ]; then
            mkdir -p "$(dirname "$project_file")"
            cp "$external_file" "$project_file"
            git add "$project_file"
            SYNCED_FILES+=("$file (external → project)")
        else
            if [ -f "$project_file" ]; then
                rm "$project_file"
                git add "$project_file"
                SYNCED_FILES+=("$file (deleted, synced from external)")
            fi
        fi
        continue
    fi

    # Case 2: Only project changed → nothing to do (post-commit handles it)
    if [ "$project_changed" = true ] && [ "$external_changed" = false ]; then
        continue
    fi

    # Case 3: Both changed → attempt 3-way merge
    if [ "$project_changed" = true ] && [ "$external_changed" = true ]; then
        if [ ! -f "$project_file" ] || [ ! -f "$external_file" ]; then
            CONFLICTED_FILES+=("$file (one side deleted, other side modified)")
            HAS_CONFLICTS=1
            continue
        fi

        base_tmp=$(mktemp)
        git show "HEAD:internal/$file" > "$base_tmp" 2>/dev/null

        if [ $? -ne 0 ]; then
            rm -f "$base_tmp"
            CONFLICTED_FILES+=("$file (new on both sides)")
            HAS_CONFLICTS=1
            continue
        fi

        project_tmp=$(mktemp)
        cp "$project_file" "$project_tmp"

        git merge-file "$project_tmp" "$base_tmp" "$external_file"
        merge_result=$?

        if [ $merge_result -eq 0 ]; then
            cp "$project_tmp" "$project_file"
            git add "$project_file"
            SYNCED_FILES+=("$file (auto-merged)")
        else
            cp "$project_tmp" "$project_file"
            CONFLICTED_FILES+=("$file")
            HAS_CONFLICTS=1
        fi

        rm -f "$base_tmp" "$project_tmp"
    fi

done <<< "$ALL_FILES"

# Report synced files
if [ ${#SYNCED_FILES[@]} -gt 0 ]; then
    echo "✔ Pre-commit sync:"
    for f in "${SYNCED_FILES[@]}"; do
        echo "  $f"
    done
fi

# If conflicts, abort
if [ $HAS_CONFLICTS -eq 1 ]; then
    echo "" >&2
    echo "⚠ Commit aborted — merge conflicts detected:" >&2
    for f in "${CONFLICTED_FILES[@]}"; do
        echo "  ✗ $f" >&2
    done
    echo "" >&2
    echo "Resolve the conflicts in the project files, then commit again." >&2
    echo "Conflict markers (<<<<<<< / ======= / >>>>>>>) are in the files." >&2
    exit 1
fi

exit 0
